# =============================================================
# ObsiRAG — Configuration
# Copier ce fichier en .env et adapter les valeurs
# =============================================================

# ---- Coffre Obsidian ----------------------------------------
# Chemin ABSOLU vers votre coffre sur l'hôte
VAULT_PATH=/path/to/your/obsidian/vault

# Répertoire des données système ObsiRAG (volume Docker, HORS coffre Obsidian)
# ChromaDB, index, stats, queries — jamais synchronisés par iCloud
APP_DATA_DIR=/app/data

# ---- LM Studio ----------------------------------------------
# Depuis Docker, utiliser host.docker.internal pour joindre l'hôte
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1

# Nom exact du modèle de chat chargé dans LM Studio
LMSTUDIO_CHAT_MODEL=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF

# (Optionnel) Modèle d'embedding LM Studio — laisser vide pour utiliser
# les embeddings locaux sentence-transformers (recommandé)
LMSTUDIO_EMBED_MODEL=

# ---- Embeddings locaux (sentence-transformers) --------------
# Modèle multilingue — supporte le français nativement
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ---- Logging ------------------------------------------------
LOG_LEVEL=INFO

# ---- Auto-apprentissage ------------------------------------
AUTOLEARN_ENABLED=true

# Intervalle entre chaque cycle (minutes)
AUTOLEARN_INTERVAL_MINUTES=60

# Nombre maximum de notes traitées par cycle
AUTOLEARN_MAX_NOTES_PER_RUN=5

# Fenêtre de détection des nouvelles notes (heures)
AUTOLEARN_LOOKBACK_HOURS=24

# ---- RAG ----------------------------------------------------
# Taille des chunks (en mots)
CHUNK_SIZE_WORDS=350

# Chevauchement entre chunks (en mots)
CHUNK_OVERLAP_WORDS=50

# Nombre de chunks retournés par la recherche sémantique
SEARCH_TOP_K=10

# Nombre maximum de chunks injectés dans le contexte LLM
MAX_CONTEXT_CHUNKS=12

# ---- WUDD.ai — Entités NER officielle ------------------
# URL de base du serveur WUDD.ai (sans slash final)
# Ex: http://localhost:5050
WUDDAI_ENTITIES_URL=http://localhost:5050
