{
  "name": "obsirag-expo",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:export": "expo export --platform web && node ./scripts/postprocess-web-export.mjs",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node ./scripts/smoke-api.mjs",
    "test:web-export": "node ./scripts/smoke-web-export.mjs",
    "test:ui": "jest --runInBand tests/ui"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/tests/ui/**/*.test.tsx"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest.setup.ts"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.59.20",
    "d3-force": "^3.0.0",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.53.1",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "vis-network": "^10.0.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-static-block": "^7.28.6",
    "@types/d3-force": "^3.0.10",
    "@types/jest": "29.5.14",
    "@types/node": "22.15.30",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "19.1.0",
    "babel-plugin-polyfill-corejs3": "^0.14.2",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "playwright": "^1.59.1",
    "react-test-renderer": "19.1.0",
    "tsx": "4.21.0",
    "typescript": "~5.9.2"
  }
}
