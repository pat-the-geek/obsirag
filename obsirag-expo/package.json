{
  "name": "obsirag-expo",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:export": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node ./scripts/smoke-api.mjs",
    "test:ui": "jest --runInBand tests/ui"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/tests/ui/**/*.test.tsx"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest.setup.ts"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@tanstack/react-query": "^5.59.20",
    "d3-force": "^3.0.0",
    "expo": "~52.0.30",
    "expo-asset": "~11.0.5",
    "expo-font": "~13.0.4",
    "expo-router": "~4.0.17",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.53.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5",
    "vis-network": "^10.0.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-static-block": "^7.28.6",
    "@types/d3-force": "^3.0.10",
    "@types/jest": "29.5.14",
    "@types/node": "22.15.30",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "18.3.1",
    "jest": "29.2.1",
    "jest-expo": "52.0.6",
    "react-test-renderer": "18.3.1",
    "tsx": "4.21.0",
    "typescript": "~5.6.3"
  }
}
